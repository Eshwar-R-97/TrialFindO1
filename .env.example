# Optional: bypass Vite proxy and call Flask directly (fixes stubborn empty 404s in dev).
# Must match where `python app.py` listens (default http://127.0.0.1:5050).
# VITE_API_BASE_URL=http://127.0.0.1:5050

FEATHERLESS_API_KEY=your_featherless_key_here

# Tinyfish (Mayo Clinic browser agent). You can add more keys to unlock real
# parallelism — we run ~2 browser sessions per key, so more keys = more
# concurrent Mayo detail scrapes. Leave unused slots blank or remove them.
TINYFISH_API_KEY=your_tinyfish_key_here
TINYFISH_API_KEY_2=
TINYFISH_API_KEY_3=
# Override if your plan supports more/fewer simultaneous sessions per key.
# TINYFISH_SESSIONS_PER_KEY=2
# Hard override for total concurrent Mayo detail agents (defaults to
# TINYFISH_SESSIONS_PER_KEY × number of keys configured).
# MAYO_MAX_CONCURRENCY=6
# How many Mayo trial detail pages to scrape per run. Defaults to the
# concurrency cap above (so every trial is scraped in ONE parallel wave).
# MAYO_MAX_TRIALS=6

# Register a free key at https://clinicaltrialsapi.cancer.gov/ and paste it here.
NCI_API_KEY=your_nci_cts_key_here
